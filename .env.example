# ══════════════════════════════════════════════════════
#  AgriGov — Configuration Email (SMTP)
#  Copiez ce fichier en .env et remplissez vos valeurs
# ══════════════════════════════════════════════════════

# ── Option 1 : Gmail (recommandé pour les tests) ──
# 1. Activez la "Validation en 2 étapes" sur votre compte Google
# 2. Allez dans : Compte Google → Sécurité → Mots de passe des applications
# 3. Créez un "Mot de passe d'application" pour "Mail"
# 4. Utilisez ce mot de passe de 16 caractères ci-dessous

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre.email@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=AgriGov <votre.email@gmail.com>

# ── Option 2 : Outlook / Hotmail ──
# EMAIL_HOST=smtp.office365.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=votre.email@outlook.com
# EMAIL_HOST_PASSWORD=votre_mot_de_passe

# ── Option 3 : Serveur SMTP professionnel (production) ──
# EMAIL_HOST=mail.agrigov.dz
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@agrigov.dz
# EMAIL_HOST_PASSWORD=votre_mot_de_passe
# DEFAULT_FROM_EMAIL=AgriGov <noreply@agrigov.dz>
